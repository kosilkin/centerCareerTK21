    grid-column: auto;
  }
}

@media (max-width: 860px) {
  body[data-page="news"] .news-page-card-inner {
    grid-template-columns: 1fr;
  }

  body[data-page="news"] .news-page-cover {
    min-height: 220px;
  }
}


